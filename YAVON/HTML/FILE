<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>品牌雅风家具</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100%;
            overflow-x: hidden;
        }

        body {
            font-family: Arial, "Microsoft YaHei", sans-serif;
            background: #fff;
            color: #333;
        }

        /* 导航栏 */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            padding: 20px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: rgba(0, 0, 0, 0.9);
            transition: background 0.3s;
        }

        .nav-menu {
            display: flex;
            gap: 50px;
        }

        .nav-menu a {
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            letter-spacing: 1px;
            transition: color 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
        }

        .nav-menu a span {
            font-size: 11px;
            color: #999;
            text-transform: uppercase;
        }

        .nav-menu a:hover {
            color: #60aeda;
        }

        .nav-menu a:hover span {
            color: #60aeda;
        }

        /* Logo */
        .logo {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .logo-svg {
            width: 70px;
            height: 70px;
            transition: transform 1s ease;
        }

        .logo:hover .logo-svg {
            transform: rotate(30deg);
        }

        .logo-text {
            margin-top: 5px;
            font-size: 14px;
            letter-spacing: 5px;
            font-weight: bold;
            color: #fff;
        }

        /* 右侧图标 */
        .header-icons {
            display: flex;
            gap: 20px;
        }

        .header-icons svg {
            width: 20px;
            height: 20px;
            fill: #fff;
            cursor: pointer;
            transition: fill 0.3s;
        }

        .header-icons svg:hover {
            fill: #60aeda;
        }

        /* Banner区域 - 全屏带背景图片 */
        .banner {
            position: relative;
            width: 100%;
            min-height: 100vh;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
            background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1920');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 150px 60px 60px;
            overflow: hidden;
        }

        .banner::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1;
        }

        .banner-content {
            position: relative;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
            max-width: 1600px;
            margin: 0 auto;
            gap: 100px;
        }

        .banner-text {
            flex: 1;
            max-width: 700px;
        }

        .banner-text h1 {
            font-size: 72px;
            font-weight: bold;
            letter-spacing: 12px;
            line-height: 1.3;
            color: #fff;
            margin-bottom: 30px;
            animation: fadeInLeft 1s ease-out;
        }

        .banner-text .subtitle {
            font-size: 24px;
            letter-spacing: 10px;
            color: #60aeda;
            animation: fadeInLeft 1.5s ease-out;
        }

        .banner-text .line {
            width: 80px;
            height: 3px;
            background: #60aeda;
            margin: 30px 0;
            animation: fadeInLeft 2s ease-out;
        }

        .banner-text p {
            font-size: 16px;
            line-height: 2.2;
            color: rgba(255, 255, 255, 0.9);
            max-width: 600px;
            animation: fadeInLeft 2.5s ease-out;
        }

        .bottom-features {
            position: absolute;
            bottom: 60px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 100px;
            z-index: 10;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 15px;
            color: #fff;
            transition: transform 0.3s;
        }

        .feature-item:hover {
            transform: translateY(-5px);
        }

        .feature-item svg {
            width: 45px;
            height: 45px;
            fill: #60aeda;
        }

        .feature-item div {
            display: flex;
            flex-direction: column;
        }

        .feature-item strong {
            font-size: 16px;
            letter-spacing: 2px;
            margin-bottom: 3px;
        }

        .feature-item span {
            color: rgba(255, 255, 255, 0.8);
            font-size: 12px;
        }

        .advantages {
            padding: 100px 0;
            background: #fff;
            width: 100%;
        }

        .advantages-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 0 60px;
        }

        .section-header {
            margin-bottom: 60px;
            max-width: 1000px;
        }

        .section-header h2 {
            font-size: 36px;
            letter-spacing: 8px;
            margin-bottom: 15px;
            color: #000;
        }

        .section-header h3 {
            font-size: 24px;
            color: #333;
            margin-bottom: 25px;
        }

        .section-header p {
            font-size: 15px;
            line-height: 2;
            color: #666;
            max-width: 900px;
        }

        .advantages-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 40px;
            width: 100%;
        }

        .advantage-card {
            position: relative;
            height: 550px;
            overflow: hidden;
            cursor: pointer;
            transition: transform 0.3s;
            border-radius: 8px;
        }

        .advantage-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        }

        .advantage-card-image {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            transition: transform 0.5s;
        }

        .advantage-card:hover .advantage-card-image {
            transform: scale(1.08);
        }

        .advantage-card-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.3);
            transition: background 0.3s;
        }

        .advantage-card:hover .advantage-card-overlay {
            background: rgba(0, 0, 0, 0.5);
        }

        .advantage-card-content {
            position: absolute;
            top: 40px;
            left: 40px;
            right: 40px;
            z-index: 10;
            color: #fff;
        }

        .advantage-card-content h3 {
            font-size: 32px;
            margin-bottom: 20px;
            letter-spacing: 2px;
            font-weight: bold;
        }

        .advantage-card-content p {
            font-size: 14px;
            line-height: 2;
            color: rgba(255, 255, 255, 0.95);
        }

        .advantage-card-footer {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 25px 40px;
            background: rgba(255, 255, 255, 0.98);
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 10;
        }

        .advantage-card-footer a {
            color: #000;
            text-decoration: none;
            font-weight: bold;
            font-size: 14px;
            transition: color 0.3s;
        }

        .advantage-card-footer a:hover {
            color: #60aeda;
        }

        .advantage-card-footer svg {
            width: 24px;
            height: 24px;
            fill: #60aeda;
            transition: transform 0.3s;
        }

        .advantage-card:hover .advantage-card-footer svg {
            transform: translateX(5px);
        }

        @keyframes fadeInLeft {
            from {
                opacity: 0;
                transform: translateX(-50px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @media (max-width: 1200px) {
            .banner-content {
                flex-direction: column;
                gap: 50px;
            }

            .banner-text h1 {
                font-size: 48px;
            }

            .bottom-features {
                gap: 50px;
            }

            .advantages-grid {
                grid-template-columns: 1fr;
            }

            .advantages-container {
                padding: 0 30px;
            }
        }

        @media (max-width: 768px) {
            .header {
                padding: 15px 30px;
            }

            .nav-menu {
                gap: 25px;
            }

            .banner {
                padding: 120px 30px 30px;
            }

            .banner-text h1 {
                font-size: 36px;
                letter-spacing: 6px;
            }

            .bottom-features {
                flex-direction: column;
                gap: 20px;
            }

            .advantages {
                padding: 60px 0;
            }

            .advantage-card {
                height: 450px;
            }
        }
    </style>
</head>
